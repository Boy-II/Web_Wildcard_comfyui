# ── 資料庫 ──────────────────────────────────────────────
# PostgreSQL（Docker Compose 預設）
DATABASE_URL=postgresql://wildcard_user:wildcard_pass@db:5432/wildcard_db
# SQLite（本機開發，不需 PostgreSQL）
# DATABASE_URL=sqlite:///data/wildcard.db

# ── Flask ────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ── Ollama ───────────────────────────────────────────────
# Docker 容器內存取宿主機 Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:8b

# ── ComfyUI Wildcard 路徑 ─────────────────────────────────
# 對應 docker-compose.yml volume mount 的來源路徑
# Windows 範例：D:/ComfyUI/custom_nodes/comfyui-adaptiveprompts/wildcards
# macOS/Linux 範例：/home/user/ComfyUI/wildcards
COMFYUI_WILDCARD_PATH=./comfy_wildcard
